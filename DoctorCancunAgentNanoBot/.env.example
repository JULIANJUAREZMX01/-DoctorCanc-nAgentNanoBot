# ============================================================
# DoctorCancúnAgentNanoBot — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values

# --- App ---
ENVIRONMENT=development
LOG_LEVEL=INFO
APP_HOST=0.0.0.0
APP_PORT=8000

# --- LLM Providers (at least one required) ---
# Priority: Ollama (1) → Anthropic (2) → Groq (3) → OpenAI (4)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
LLM_ROTATION_STRATEGY=priority

# --- Telegram ---
TELEGRAM_TOKEN=
TELEGRAM_OWNER_ID=
TELEGRAM_ENABLED=true

# --- WhatsApp ---
WHATSAPP_ENABLED=false
WHATSAPP_NUMBER=
WHATSAPP_BRIDGE_PORT=3001

# --- Business Info ---
BUSINESS_NAME=iDoctor Cancún
BUSINESS_PHONE=9982134708
BUSINESS_ADDRESS=C. 71 SM 91 Mza 88 Lt 17, Tumben Cuxtal, 77516 Cancún, Q.R.
BUSINESS_GMAPS_URL=https://maps.app.goo.gl/ze4432vtrbeBLDKn8
BUSINESS_FACEBOOK=https://www.facebook.com/idoctorcancunn91/
BUSINESS_SLOGAN=iDoctor... ¡recupera tu vida!

# --- Database ---
DATABASE_URL=sqlite:///data/leads.db

# --- Notifications ---
OWNER_NOTIFICATION_CHANNEL=telegram

# --- AWS S3 Backups (optional) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=
S3_BACKUP_INTERVAL_HOURS=6
